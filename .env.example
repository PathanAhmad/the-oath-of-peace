# Environment variables for local dev tooling.
# Copy to .env (gitignored) and fill in real values.
# NEVER commit the real .env — see Hard Rule #4 in CLAUDE.md.

# Roblox Open Cloud API key — used by scripts/publish.mjs
# Generate at https://create.roblox.com/dashboard/credentials
# Required scope: "Place Management" (write) for both Hub + Match places.
ROBLOX_OPEN_CLOUD_KEY=

# The Universe (experience) ID containing both Hub + Match places.
# Find at https://create.roblox.com/dashboard/creations → click your experience →
# the URL path contains /creations/experience/<UNIVERSE_ID>
ROBLOX_UNIVERSE_ID=
