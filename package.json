{
	"name": "the-oath",
	"version": "0.1.0",
	"private": true,
	"description": "The Oath — 4-player co-op shooter on Roblox (Galactic Guardians vs Parasite Army)",
	"scripts": {
		"build": "rbxtsc",
		"watch": "rbxtsc -w",
		"lint": "eslint \"src/**/*.ts\"",
		"format": "prettier --write \"src/**/*.ts\" \"*.json\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.json\"",
		"check": "pnpm format:check && pnpm lint && pnpm build"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/types": "^1.0.777",
		"@typescript-eslint/eslint-plugin": "^6.7.5",
		"@typescript-eslint/parser": "^6.7.5",
		"eslint": "^7.31.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-prettier": "^3.4.0",
		"eslint-plugin-roblox-ts": "^0.0.30",
		"prettier": "^2.3.2",
		"rbxts-transformer-flamework": "^1.3.2",
		"roblox-ts": "^3.0.0",
		"typescript": "~5.5.3"
	},
	"dependencies": {
		"@flamework/components": "^1.2.2",
		"@flamework/core": "^1.2.2",
		"@flamework/networking": "^1.2.2",
		"@rbxts/profile-store": "^1.0.3",
		"@rbxts/react": "17.3.7-ts.1",
		"@rbxts/react-roblox": "17.3.7-ts.1",
		"@rbxts/t": "^3.2.1"
	},
	"engines": {
		"node": ">=20"
	}
}
